// Safe defaults for local development. Release automation can override these
// build settings at xcodebuild invocation time without touching the project.

GLOSSOLALIA_APP_PRODUCT_NAME = Glossolalia
GLOSSOLALIA_APP_DISPLAY_NAME = Glossolalia
GLOSSOLALIA_DEBUG_APP_DISPLAY_NAME = Glossolalia[DEBUG]
GLOSSOLALIA_APP_ICON_NAME = AppIconImage
GLOSSOLALIA_EXECUTABLE_NAME = glossolalia
GLOSSOLALIA_BUNDLE_ID = com.henryzoo.glossolalia
GLOSSOLALIA_DEBUG_BUNDLE_ID = $(GLOSSOLALIA_BUNDLE_ID).debug
GLOSSOLALIA_DOCK_TILE_PRODUCT_NAME = DockTilePlugin
GLOSSOLALIA_DOCK_TILE_DISPLAY_NAME = $(GLOSSOLALIA_APP_DISPLAY_NAME) Dock Tile Plugin
GLOSSOLALIA_DOCK_TILE_BUNDLE_ID = $(GLOSSOLALIA_BUNDLE_ID)-dock-tile
GLOSSOLALIA_MARKETING_VERSION = 0.1

GLOSSOLALIA_NOTIFICATION_NAMESPACE = $(GLOSSOLALIA_BUNDLE_ID)
GLOSSOLALIA_DEFAULTS_SUITE_NAME = $(GLOSSOLALIA_BUNDLE_ID)
GLOSSOLALIA_SURFACE_UTI = $(GLOSSOLALIA_BUNDLE_ID).surface-id

GLOSSOLALIA_RELEASE_NOTES_URL_TEMPLATE = https://github.com/hzoo/glossolalia/releases/tag/v{version}
GLOSSOLALIA_COMPARE_URL_TEMPLATE = https://github.com/hzoo/glossolalia/compare/{current}...{new}
GLOSSOLALIA_COMMIT_URL_TEMPLATE = https://github.com/hzoo/glossolalia/commit/{new}
GLOSSOLALIA_UPDATE_STABLE_FEED_URL = https://hzoo.github.io/glossolalia/appcast.xml
GLOSSOLALIA_UPDATE_TIP_FEED_URL = https://hzoo.github.io/glossolalia/appcast-tip.xml

GLOSSOLALIA_PERMISSION_SUBJECT = A program running within $(GLOSSOLALIA_APP_DISPLAY_NAME)
